<UserControl x:Class="ForexWidget.App.Controls.SessionTimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="18" d:DesignWidth="240">

    <Grid Height="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Name}"
                   Style="{DynamicResource LabelSecondary}"
                   VerticalAlignment="Center"/>

        <Canvas x:Name="BarCanvas"
                Grid.Column="1"
                SizeChanged="BarCanvas_SizeChanged">
            <Rectangle x:Name="RailRect"
                       Canvas.Top="2"
                       Height="14"
                       Fill="{DynamicResource SessionClosedBrush}"
                       RadiusX="2" RadiusY="2"/>
            <Rectangle x:Name="BarRect"
                       Canvas.Top="2"
                       Height="14"
                       RadiusX="2" RadiusY="2"/>
            <Rectangle x:Name="BarRect2"
                       Canvas.Top="2"
                       Height="14"
                       RadiusX="2" RadiusY="2"
                       Visibility="Collapsed"/>
            <!-- ZIndex alto: la línea NOW siempre por encima de los overlays de killzone -->
            <Rectangle x:Name="NowLine"
                       Canvas.Top="0"
                       Width="1.5"
                       Height="18"
                       Panel.ZIndex="10"
                       Fill="{DynamicResource AccentBrush}"/>
        </Canvas>
    </Grid>
</UserControl>
