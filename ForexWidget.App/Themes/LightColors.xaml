<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Valores de Config/theme.json → sección "Light" -->

    <!-- Backgrounds -->
    <Color x:Key="ColorBackground">#F5F5F5</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorPrimary">#1565C0</Color>

    <!-- Accent -->
    <Color x:Key="ColorAccent">#E53935</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#1A1A1A</Color>
    <Color x:Key="ColorTextSecondary">#666666</Color>

    <!-- Sessions -->
    <Color x:Key="ColorSessionOpen">#2E7D32</Color>
    <Color x:Key="ColorSessionClosed">#E0E0E0</Color>

    <!-- Killzones -->
    <Color x:Key="ColorKillzoneActive">#F57F17</Color>
    <Color x:Key="ColorOverlap">#00695C</Color>

    <!-- Status (ajustados para legibilidad sobre fondo claro) -->
    <Color x:Key="ColorVeryHigh">#00695C</Color>
    <Color x:Key="ColorHigh">#2E7D32</Color>
    <Color x:Key="ColorMedium">#F57F17</Color>
    <Color x:Key="ColorLow">#E65100</Color>
    <Color x:Key="ColorVeryLow">#9E9E9E</Color>

    <!-- SolidColorBrushes (mismos x:Key que Colors.xaml) -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource ColorBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="SessionOpenBrush"     Color="{StaticResource ColorSessionOpen}"/>
    <SolidColorBrush x:Key="SessionClosedBrush"   Color="{StaticResource ColorSessionClosed}"/>
    <SolidColorBrush x:Key="KillzoneBrush"        Color="{StaticResource ColorKillzoneActive}"/>
    <SolidColorBrush x:Key="OverlapBrush"         Color="{StaticResource ColorOverlap}"/>
</ResourceDictionary>
