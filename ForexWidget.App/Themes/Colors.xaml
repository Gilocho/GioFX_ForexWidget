<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="ColorBackground">#1A1A2E</Color>
    <Color x:Key="ColorSurface">#16213E</Color>
    <Color x:Key="ColorPrimary">#0F3460</Color>

    <!-- Accent -->
    <Color x:Key="ColorAccent">#E94560</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#FFFFFF</Color>
    <Color x:Key="ColorTextSecondary">#A0A0B0</Color>

    <!-- Sessions -->
    <Color x:Key="ColorSessionOpen">#00AA44</Color>
    <Color x:Key="ColorSessionClosed">#2A2A3E</Color>

    <!-- Killzones -->
    <Color x:Key="ColorKillzoneActive">#FFB300</Color>
    <Color x:Key="ColorOverlap">#00FFAA</Color>

    <!-- Status -->
    <Color x:Key="ColorVeryHigh">#00FFAA</Color>
    <Color x:Key="ColorHigh">#00AA44</Color>
    <Color x:Key="ColorMedium">#FFB300</Color>
    <Color x:Key="ColorLow">#FF8800</Color>
    <Color x:Key="ColorVeryLow">#666680</Color>

    <!-- SolidColorBrushes -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource ColorBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="SessionOpenBrush"     Color="{StaticResource ColorSessionOpen}"/>
    <SolidColorBrush x:Key="SessionClosedBrush"   Color="{StaticResource ColorSessionClosed}"/>
    <SolidColorBrush x:Key="KillzoneBrush"        Color="{StaticResource ColorKillzoneActive}"/>
    <SolidColorBrush x:Key="OverlapBrush"         Color="{StaticResource ColorOverlap}"/>
</ResourceDictionary>
