<Window x:Class="ForexWidget.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ForexWidget.App.ViewModels"
        xmlns:controls="clr-namespace:ForexWidget.App.Controls"
        Title="ForexWidget"
        Width="320" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        Opacity="{Binding WindowOpacity}"
        Icon="/Assets/AppIcon.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- Raíz arrastrable -->
    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource PrimaryBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <StackPanel Margin="12">

            <!-- ── HEADER: Reloj + Botón cerrar ── -->
            <!-- En minimalista se oculta entero: el reloj baja en chiquito al pie
                 del timeline y los botones suben a la fila de SESSIONS -->
            <Grid Visibility="{Binding IsMinimalistMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding CurrentTimeUtc}"
                                   Style="{DynamicResource ClockStyle}"/>
                        <TextBlock Text="{Binding TimeDisplayLabel}"
                                   Style="{DynamicResource LabelSecondary}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="6,0,0,4"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CurrentDateUtc}"
                               Style="{DynamicResource LabelSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Command="{Binding OpenSupportCommand}"
                            Content="♥"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding OpenSettingsCommand}"
                            Content="⚙"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding CloseAppCommand}"
                            Content="✕"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <Separator Margin="0,8,0,8"
                       Visibility="{Binding IsMinimalistMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <!-- ── WEEKEND CLOSED BANNER ── -->
            <Border Background="#2A0A0A"
                    CornerRadius="4"
                    Padding="8,6"
                    Margin="0,0,0,8"
                    Visibility="{Binding IsWeekendClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="⛔  MARKET CLOSED — Weekend"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- ── DST WARNING ── -->
            <Border Background="#1A1A00"
                    CornerRadius="4"
                    Padding="8,6"
                    Margin="0,0,0,8"
                    Visibility="{Binding IsDstWarningActive, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding DstWarningMessage}"
                           Foreground="{DynamicResource KillzoneBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ── SESSION TIMELINE ── -->
            <!-- En minimalista los botones ♥/⚙/✕ viven en esta fila (esquina sup. derecha);
                 en modo normal siguen en el header y aquí quedan colapsados -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding TimeDisplayLabel, StringFormat='SESSIONS  ({0})'}"
                           Style="{DynamicResource LabelSecondary}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Visibility="{Binding IsMinimalistMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Command="{Binding OpenSupportCommand}"
                            Content="♥"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            FontSize="11"
                            Padding="2,0"
                            Cursor="Hand"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding OpenSettingsCommand}"
                            Content="⚙"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            FontSize="11"
                            Padding="2,0"
                            Cursor="Hand"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding CloseAppCommand}"
                            Content="✕"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            FontSize="11"
                            Padding="2,0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Marcadores de hora, alineados con la columna de barras -->
            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="00" Style="{DynamicResource LabelSecondary}" FontSize="9" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="0" Text="06" Style="{DynamicResource LabelSecondary}" FontSize="9" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="1" Text="12" Style="{DynamicResource LabelSecondary}" FontSize="9" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="18" Style="{DynamicResource LabelSecondary}" FontSize="9" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="24" Style="{DynamicResource LabelSecondary}" FontSize="9" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>

            <!-- Filas de sesiones -->
            <ItemsControl ItemsSource="{Binding Sessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:SessionTimelineControl
                            Margin="0,2,0,2"
                            NowFraction="{Binding DataContext.NowLinePosition, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Reloj + fecha compactos al pie del timeline, solo en minimalista
                 (reemplazan al header completo, que en este modo está oculto) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0"
                        Visibility="{Binding IsMinimalistMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding CurrentTimeUtc}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="10"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TimeDisplayLabel}"
                           Style="{DynamicResource LabelSecondary}"
                           FontSize="9"
                           Margin="4,0,0,0"
                           VerticalAlignment="Bottom"/>
                <TextBlock Text="{Binding CurrentDateUtc, StringFormat=' · {0}'}"
                           Style="{DynamicResource LabelSecondary}"
                           FontSize="9"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <!-- Leyenda de killzones habilitadas: qué color es cuál en el overlay -->
            <ItemsControl ItemsSource="{Binding KillzoneLegend}" Margin="55,4,0,0"
                          Visibility="{Binding IsMinimalistMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                            <Rectangle Width="8" Height="8"
                                       Fill="{Binding Color}"
                                       RadiusX="2" RadiusY="2"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="9"
                                       Style="{DynamicResource LabelSecondary}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Todo lo de abajo se oculta completo en modo minimalista -->
            <StackPanel Visibility="{Binding IsMinimalistMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">

            <Separator Margin="0,8,0,8"/>

            <!-- ── MARKET CONTEXT ── -->
            <TextBlock Text="MARKET CONTEXT"
                       Style="{DynamicResource LabelSecondary}"
                       Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Phase"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding MarketPhase}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold"/>
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Activity"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding InstitutionalActivity}"
                           FontWeight="SemiBold"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Liquidity"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding LiquidityLevel}"
                           Foreground="{Binding LiquidityColor}"
                           FontWeight="Bold"/>
            </Grid>

            <!-- ── HIGH IMPACT NEWS ── -->
            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="NEXT HIGH IMPACT"
                       Style="{DynamicResource LabelSecondary}"
                       Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding NextHighImpactNews}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="{Binding NextHighImpactTime}"
                           Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
            </Grid>

            <!-- ── KILLZONES ACTIVAS ── -->
            <StackPanel Visibility="{Binding Killzones.Count, Converter={StaticResource CountToVisibilityConverter}}">
                <TextBlock Text="KILLZONES ACTIVE"
                           Style="{DynamicResource LabelSecondary}"
                           Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding Killzones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Rectangle Width="8" Height="8"
                                               Fill="{Binding Color}"
                                               RadiusX="2" RadiusY="2"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimeUntil}"
                                           Style="{DynamicResource LabelSecondary}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator Margin="0,8,0,8"/>
            </StackPanel>

            <!-- ── PRÓXIMA KILLZONE (cuando ninguna está activa) ── -->
            <StackPanel Visibility="{Binding NextKillzoneText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock Text="KILLZONES"
                           Style="{DynamicResource LabelSecondary}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding NextKillzoneText}"
                           Style="{DynamicResource LabelSecondary}"
                           Foreground="{DynamicResource KillzoneBrush}"/>
                <Separator Margin="0,8,0,8"/>
            </StackPanel>

            <!-- ── NEXT MILESTONE ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding NextMilestone}"
                           Style="{DynamicResource LabelSecondary}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding NextMilestoneTime}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="Bold"/>
            </Grid>

            <!-- ── SYSTEM STATUS (discreto) ── -->
            <Separator Margin="0,4,0,4"/>
            <Grid Opacity="0.6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Internet"
                           Style="{DynamicResource LabelSecondary}" FontSize="9"/>
                <TextBlock Grid.Column="1" Text="{Binding InternetStatus}"
                           Style="{DynamicResource LabelSecondary}" FontSize="9"/>
            </Grid>
            <Grid Opacity="0.6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Holidays"
                           Style="{DynamicResource LabelSecondary}" FontSize="9"/>
                <TextBlock Grid.Column="1" Text="{Binding HolidayDataStatus}"
                           Style="{DynamicResource LabelSecondary}" FontSize="9"/>
            </Grid>
            <Grid Opacity="0.6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Calendar"
                           Style="{DynamicResource LabelSecondary}" FontSize="9"/>
                <TextBlock Grid.Column="1" Text="{Binding CalendarDataStatus}"
                           Style="{DynamicResource LabelSecondary}" FontSize="9"/>
            </Grid>

            <!-- ── FOOTER ── -->
            <TextBlock Text="{Binding AppVersionText, StringFormat='ForexWidget {0} · UTC · MMM'}"
                       Style="{DynamicResource LabelSecondary}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"
                       Opacity="0.4"/>

            </StackPanel>
            <!-- Fin del bloque oculto en modo minimalista -->
        </StackPanel>
    </Border>
</Window>
