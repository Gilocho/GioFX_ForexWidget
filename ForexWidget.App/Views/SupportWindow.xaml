<Window x:Class="ForexWidget.App.Views.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support ForexWidget"
        Width="340" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/AppIcon.ico">

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource PrimaryBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <StackPanel Margin="16">

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SUPPORT"
                           Style="{DynamicResource ClockStyle}"
                           FontSize="14"/>
                <Button Grid.Column="1"
                        Command="{Binding CloseCommand}"
                        Content="✕"
                        Background="Transparent"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0"
                        FontSize="13"
                        Cursor="Hand"
                        VerticalAlignment="Top"/>
            </Grid>

            <!-- Banner si los placeholders siguen sin editar -->
            <Border Background="#4A0000" CornerRadius="4" Padding="8" Margin="0,0,0,12"
                    Visibility="{Binding ShowPlaceholderWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="⚠ Donation info not configured — edit SupportInfo.cs before distributing"
                           Foreground="White" TextWrapping="Wrap" FontSize="10"/>
            </Border>

            <TextBlock Text="If ForexWidget is useful to you, consider supporting its development."
                       TextWrapping="Wrap" Margin="0,0,0,12"/>

            <Button Content="☕ Donate via PayPal"
                    Command="{Binding OpenPayPalCommand}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Padding="0,8"
                    Cursor="Hand"
                    Margin="0,0,0,14"/>

            <TextBlock Text="USDT" Style="{DynamicResource LabelSecondary}" Margin="0,0,0,4"/>

            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="TRC20 (Tron)" FontWeight="Bold" FontSize="10"/>
                    <TextBlock Text="{Binding Trc20Address}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"/>
                    <Button Content="Copy" Command="{Binding CopyTrc20Command}"
                            Margin="0,4,0,0" Padding="10,2" HorizontalAlignment="Left"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="BEP20 (BNB Smart Chain)" FontWeight="Bold" FontSize="10"/>
                    <TextBlock Text="{Binding Bep20Address}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"/>
                    <Button Content="Copy" Command="{Binding CopyBep20Command}"
                            Margin="0,4,0,0" Padding="10,2" HorizontalAlignment="Left"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="ERC20 (Ethereum)" FontWeight="Bold" FontSize="10"/>
                    <TextBlock Text="{Binding Erc20Address}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"/>
                    <Button Content="Copy" Command="{Binding CopyErc20Command}"
                            Margin="0,4,0,0" Padding="10,2" HorizontalAlignment="Left"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <TextBlock Text="⚠ Only send USDT on the matching network. Wrong network = lost funds."
                       Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" FontSize="9" Margin="0,8,0,0"/>
        </StackPanel>
    </Border>
</Window>
