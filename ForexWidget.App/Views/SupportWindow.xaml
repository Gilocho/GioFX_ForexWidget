<Window x:Class="ForexWidget.App.Views.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support ForexWidget"
        Width="320" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/AppIcon.ico"
        Background="{DynamicResource BackgroundBrush}">
    <StackPanel Margin="16">
        <TextBlock Text="If ForexWidget is useful to you, consider supporting its development."
                   TextWrapping="Wrap" Margin="0,0,0,16"/>
        <Button Content="♥ Support this project"
                Command="{Binding OpenSupportPageCommand}"
                Background="{DynamicResource PrimaryBrush}"
                Foreground="{DynamicResource TextPrimaryBrush}"
                BorderThickness="0"
                Padding="0,8"
                Cursor="Hand"/>
        <TextBlock Text="Opens the project's GitHub page in your browser."
                   Style="{DynamicResource LabelSecondary}" Margin="0,8,0,0"
                   TextWrapping="Wrap" FontSize="9" Opacity="0.7"/>
    </StackPanel>
</Window>
