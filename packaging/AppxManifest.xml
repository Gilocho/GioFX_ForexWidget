<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
         xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
         xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
         IgnorableNamespaces="uap rescap">

  <!-- Identidad real asignada por Microsoft Partner Center (rama store-release).
       Microsoft firma el paquete durante la certificacion, por lo que aqui NO
       aplica el certificado autofirmado CN=GioFX del flujo de sideload (rama main). -->
  <Identity Name="FxGio.ForexWidget"
            Publisher="CN=A300F14C-B8C5-458D-9D38-45A17EC54C60"
            Version="1.0.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>ForexWidget</DisplayName>
    <PublisherDisplayName>FxGio</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="ForexWidget"
                 Executable="ForexWidget.App.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="ForexWidget"
                          Description="Forex market context widget — sessions, killzones, alerts"
                          BackgroundColor="transparent"
                          Square150x150Logo="Images\Square150x150Logo.png"
                          Square44x44Logo="Images\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <!-- runFullTrust: requerido para apps de escritorio Win32/WPF empaquetadas -->
    <rescap:Capability Name="runFullTrust" />
    <!-- internetClient: descarga del feed de Forex Factory -->
    <Capability Name="internetClient" />
  </Capabilities>
</Package>
